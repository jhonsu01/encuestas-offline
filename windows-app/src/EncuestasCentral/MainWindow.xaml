<Window x:Class="EncuestasCentral.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EncuestasCentral"
        Title="Encuestas Central" Height="700" Width="1040"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#00695C" Padding="14,10">
            <TextBlock Text="📋 Encuestas Central — Servidor local (offline / LAN)"
                       Foreground="White" FontSize="18" FontWeight="Bold" />
        </Border>

        <TabControl Margin="8">
            <!-- ===================== SERVIDOR ===================== -->
            <TabItem Header="Servidor">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <Button x:Name="BtnStart" Content="▶ Iniciar servidor" Padding="12,6" Margin="0,0,8,0" Click="StartServer_Click" />
                        <Button x:Name="BtnStop" Content="■ Detener" Padding="12,6" Margin="0,0,8,0" Click="StopServer_Click" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText" Grid.Row="1" Margin="0,10" FontWeight="SemiBold"
                               Text="Servidor detenido." />
                    <GroupBox Header="Registro de actividad" Grid.Row="2">
                        <ListBox x:Name="LogList" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ===================== EDITOR VISUAL ===================== -->
            <TabItem Header="Editor de encuestas">
                <Grid x:Name="EditorRoot" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Lista de encuestas -->
                    <DockPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock DockPanel.Dock="Top" Text="Encuestas" FontWeight="Bold" Margin="0,0,0,6" />
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="＋ Nueva" Padding="8,4" Margin="0,0,4,0" Click="NuevaEncuesta_Click" />
                                <Button Content="⧉ Clonar" Padding="8,4" Margin="0,0,4,0" Click="ClonarEncuesta_Click" />
                                <Button Content="🗑 Eliminar" Padding="8,4" Click="EliminarEncuesta_Click" />
                            </StackPanel>
                            <TextBlock x:Name="PublishedCount" Margin="0,6,0,0" Foreground="#555" />
                        </StackPanel>
                        <ListBox x:Name="SurveysList"
                                 ItemsSource="{Binding Surveys}"
                                 SelectedItem="{Binding Selected, Mode=TwoWay}"
                                 DisplayMemberPath="Title" />
                    </DockPanel>

                    <!-- Constructor de la encuesta seleccionada -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding Selected}">
                            <TextBlock Text="Título de la encuesta" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="15" />

                            <TextBlock Text="Descripción" FontWeight="SemiBold" Margin="0,8,0,0" />
                            <TextBox Text="{Binding Description}" AcceptsReturn="True" MinHeight="38" TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Horario inicio (HH:mm)" />
                                    <TextBox Text="{Binding StartTime}" Width="110" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Horario fin (HH:mm)" />
                                    <TextBox Text="{Binding EndTime}" Width="110" />
                                </StackPanel>
                            </StackPanel>

                            <Separator Margin="0,12" />
                            <TextBlock Text="Preguntas" FontWeight="Bold" FontSize="14" Margin="0,0,0,6" />

                            <ItemsControl ItemsSource="{Binding Questions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6"
                                                Padding="10" Margin="0,0,0,8" Background="White">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Tipo:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                    <ComboBox Width="170"
                                                              ItemsSource="{x:Static local:QuestionTypes.All}"
                                                              SelectedValuePath="Code" DisplayMemberPath="Display"
                                                              SelectedValue="{Binding Type, Mode=TwoWay}" />
                                                    <CheckBox Content="Obligatoria" IsChecked="{Binding Required}"
                                                              VerticalAlignment="Center" Margin="16,0,0,0" />
                                                    <Button Content="↑" Width="30" Margin="16,0,2,0" Click="SubirPregunta_Click" ToolTip="Subir" />
                                                    <Button Content="↓" Width="30" Margin="0,0,2,0" Click="BajarPregunta_Click" ToolTip="Bajar" />
                                                    <Button Content="✕" Width="30" Click="EliminarPregunta_Click" ToolTip="Eliminar pregunta" />
                                                </StackPanel>

                                                <TextBlock Text="Pregunta / etiqueta" Margin="0,8,0,0" />
                                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />

                                                <StackPanel Visibility="{Binding IsChoice, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Opciones (separadas por coma)" Margin="0,8,0,0" />
                                                    <TextBox Text="{Binding OptionsText}" />
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                            Visibility="{Binding IsNumber, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Mínimo:" VerticalAlignment="Center" />
                                                    <TextBox Text="{Binding MinText}" Width="70" Margin="6,0,16,0" />
                                                    <TextBlock Text="Máximo:" VerticalAlignment="Center" />
                                                    <TextBox Text="{Binding MaxText}" Width="70" Margin="6,0,0,0" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Añadir pregunta:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox x:Name="NewTypeCombo" Width="170"
                                          ItemsSource="{x:Static local:QuestionTypes.All}"
                                          SelectedValuePath="Code" DisplayMemberPath="Display" />
                                <Button Content="＋ Agregar" Padding="10,4" Margin="8,0,0,0" Click="AnadirPregunta_Click" />
                            </StackPanel>

                            <Separator Margin="0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="💾 Guardar y publicar" Padding="14,7" Click="GuardarEncuesta_Click"
                                        Background="#00695C" Foreground="White" FontWeight="SemiBold" />
                                <Button Content="Exportar JSON…" Padding="10,7" Margin="8,0,0,0" Click="Exportar_Click" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ===================== ENCUESTADORES ===================== -->
            <TabItem Header="Encuestadores">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Actualizar" Padding="10,5" HorizontalAlignment="Left" Click="RefreshSurveyors_Click" />
                    <DataGrid x:Name="SurveyorsGrid" Grid.Row="1" Margin="0,8,0,0" IsReadOnly="True" AutoGenerateColumns="True" />
                </Grid>
            </TabItem>

            <!-- ===================== DASHBOARD ===================== -->
            <TabItem Header="Dashboard">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <Button Content="Actualizar" Padding="10,5" Margin="0,0,16,0" Click="RefreshDashboard_Click" />
                        <TextBlock x:Name="LblTotal" VerticalAlignment="Center" FontWeight="Bold" Text="Total: 0" />
                    </StackPanel>
                    <TextBlock x:Name="LblBySurveyor" Grid.Row="1" Margin="0,8" TextWrapping="Wrap" />
                    <DataGrid x:Name="ResponsesGrid" Grid.Row="2" IsReadOnly="True" AutoGenerateColumns="True" />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
