<Window x:Class="EncuestasCentral.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encuestas Central" Height="680" Width="980"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#00695C" Padding="14,10">
            <TextBlock Text="📋 Encuestas Central — Servidor local (offline / LAN)"
                       Foreground="White" FontSize="18" FontWeight="Bold" />
        </Border>

        <TabControl Margin="8">
            <!-- ===================== SERVIDOR ===================== -->
            <TabItem Header="Servidor">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <Button x:Name="BtnStart" Content="▶ Iniciar servidor" Padding="12,6" Margin="0,0,8,0" Click="StartServer_Click" />
                        <Button x:Name="BtnStop" Content="■ Detener" Padding="12,6" Margin="0,0,8,0" Click="StopServer_Click" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText" Grid.Row="1" Margin="0,10" FontWeight="SemiBold"
                               Text="Servidor detenido." />
                    <GroupBox Header="Registro de actividad" Grid.Row="2">
                        <ListBox x:Name="LogList" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ===================== EDITOR ===================== -->
            <TabItem Header="Editor de encuestas">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="Cargar ejemplo" Padding="10,5" Margin="0,0,8,0" Click="CargarEjemplo_Click" />
                        <Button Content="Publicar" Padding="10,5" Margin="0,0,8,0" Click="Publicar_Click" />
                        <Button Content="Exportar JSON…" Padding="10,5" Click="Exportar_Click" />
                        <TextBlock x:Name="PublishedCount" VerticalAlignment="Center" Margin="16,0,0,0" />
                    </StackPanel>
                    <TextBox x:Name="EditorJson" Grid.Row="1" AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="13" />
                    <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="#555"
                               Text="El JSON se valida y se sirve en GET /surveys para que los dispositivos lo descarguen." />
                </Grid>
            </TabItem>

            <!-- ===================== ENCUESTADORES ===================== -->
            <TabItem Header="Encuestadores">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Actualizar" Padding="10,5" HorizontalAlignment="Left" Click="RefreshSurveyors_Click" />
                    <DataGrid x:Name="SurveyorsGrid" Grid.Row="1" Margin="0,8,0,0" IsReadOnly="True"
                              AutoGenerateColumns="True" />
                </Grid>
            </TabItem>

            <!-- ===================== DASHBOARD ===================== -->
            <TabItem Header="Dashboard">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <Button Content="Actualizar" Padding="10,5" Margin="0,0,16,0" Click="RefreshDashboard_Click" />
                        <TextBlock x:Name="LblTotal" VerticalAlignment="Center" FontWeight="Bold" Text="Total: 0" />
                    </StackPanel>
                    <TextBlock x:Name="LblBySurveyor" Grid.Row="1" Margin="0,8" TextWrapping="Wrap" />
                    <DataGrid x:Name="ResponsesGrid" Grid.Row="2" IsReadOnly="True" AutoGenerateColumns="True" />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
