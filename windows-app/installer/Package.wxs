<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Encuestas Central"
           Manufacturer="jhonsu01"
           Version="$(var.Version)"
           UpgradeCode="7E9C1A2B-4D3E-4F5A-9B6C-1234567890AB"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="Ya hay una versión más reciente de Encuestas Central instalada." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon.ico" SourceFile="$(var.IconFile)" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/jhonsu01/encuestas-offline" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Encuestas Central" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="Encuestas Central" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="Main" Title="Encuestas Central" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AppShortcuts" />
    </Feature>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Guid="*">
        <File Id="MainExe" Source="$(var.PublishDir)\EncuestasCentral.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Component Id="AppShortcuts" Directory="AppShortcutFolder" Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Name="Encuestas Central"
                Target="[INSTALLFOLDER]EncuestasCentral.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon.ico" />
      <Shortcut Id="DesktopShortcut"
                Directory="DesktopFolder"
                Name="Encuestas Central"
                Target="[INSTALLFOLDER]EncuestasCentral.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\jhonsu01\EncuestasCentral"
                     Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Package>
</Wix>
