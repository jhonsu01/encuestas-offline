# Normaliza a LF en el repositorio (evita CRLF en scripts de CI)
* text=auto eol=lf

# Scripts específicos de Windows conservan CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binarios
*.png binary
*.jpg binary
*.ico binary
*.jks binary
*.keystore binary
*.apk binary
*.msi binary
